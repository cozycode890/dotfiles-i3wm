[global]
    # Look & feel
    font = OperatorMono Nerd Font 10
    markup = full
    format = "<b>%s</b>\n%b"
    vertical_alignment = center
    ellipsize = end
    ignore_newline = no

  # Icons path
    icon_path = ~/.dotfiles/icons/.icons/Everforest-Dark/panel/16/:~/.dotfiles/icons/.icons/Everforest-Dark/status/symbolic/:~/.dotfiles/icons/.icons/Everforest-Dark/devices/16

    # Geometry
    width = 360
    height = (0, 300)
    origin = top-right
    offset = (16,16)
    padding = 10
    horizontal_padding = 12
    text_icon_padding = 8
    corner_radius = 10
    separator_height = 2
    gap_size = 8

    # Icons
    icon_theme = Papirus
    icon_position = left
    min_icon_size = 24
    max_icon_size = 64

    # Behavior
    sticky_history = yes
    history_length = 20
    show_indicators = yes
    indicate_hidden = yes
    sort = yes
    word_wrap = yes
    mouse_left_click = close_current
    mouse_middle_click = do_action
    mouse_right_click = close_all

    # Progress bar (uses frame/foreground by default)
    progress_bar = true
    progress_bar_height = 6
    progress_bar_min_width = 120
    progress_bar_max_width = 320
    progress_bar_frame_width = 1
    progress_bar_corner_radius = 3

    frame_color = "#cba6f7"
    separator_color= frame
    highlight = "#cba6f7"

; Catppuccin mocha
[urgency_low]
background = "#1e1e2ecc"
foreground = "#a6adc8ff"

[urgency_normal]
background = "#1e1e2e99"
foreground = "#cdd6f4ff"

[urgency_critical]
background = "#1e1e2e"
foreground = "#cdd6f4b3"
frame_color = "#f38ba8ff"

