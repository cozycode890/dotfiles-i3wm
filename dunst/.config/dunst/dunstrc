[global]
    # Look & feel
    font = OperatorMono Nerd Font 10
    allow_markup = yes
    format = "<b>%s</b>\n%b"
    vertical_alignment = center
    ellipsize = end
    ignore_newline = no

  # Icons path
    icon_path = ~/.dotfiles/icons/.icons/Everforest-Dark/panel/16/:~/.dotfiles/icons/.icons/Everforest-Dark/status/symbolic/:~/.dotfiles/icons/.icons/Everforest-Dark/devices/16

    # Geometry
    width = 360
    height = 300
    origin = top-right
    offset = 16x16
    padding = 10
    horizontal_padding = 12
    text_icon_padding = 8
    corner_radius = 10
    separator_height = 2
    gap_size = 8

    # Colors (Tokyo Night - Night)
    background = "#1a1b26"
    foreground = "#c0caf5"
    frame_color = "#7aa2f7"
    separator_color = frame

    # Transparency (0–100, higher = more transparent)
    transparency = 0

    # Icons
    icon_theme = Papirus
    icon_position = left
    min_icon_size = 24
    max_icon_size = 64

    # Behavior
    sticky_history = yes
    history_length = 20
    show_indicators = yes
    indicate_hidden = yes
    sort = yes
    word_wrap = yes
    mouse_left_click = close_current
    mouse_middle_click = do_action
    mouse_right_click = close_all

    # Progress bar (uses frame/foreground by default)
    progress_bar = true
    progress_bar_height = 6
    progress_bar_min_width = 120
    progress_bar_max_width = 320
    progress_bar_frame_width = 1
    progress_bar_corner_radius = 6

[urgency_low]
    timeout = 6
    background = "#16161e"
    foreground = "#c0caf5"
    frame_color = "#565f89"

[urgency_normal]
    timeout = 8
    background = "#1a1b26"
    foreground = "#c0caf5"
    frame_color = "#7aa2f7"  # blue
    # highlight links / actions
    highlight = "#7dcfff"

[urgency_critical]
    timeout = 0
    background = "#1a1b26"
    foreground = "#c0caf5"
    frame_color = "#f7768e"  # red
    # make title stand out
    markup = full

