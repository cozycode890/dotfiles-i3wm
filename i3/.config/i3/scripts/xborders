#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import subprocess
import threading
import webbrowser
from typing import Any

import cairo
import gi
import requests

VERSION = 3.4

INSIDE = "inside"
OUTSIDE = "outside"
CENTER = "center"
BORDER_MODES = [INSIDE, OUTSIDE, CENTER]

# Defaults (overridden by args/config)
BORDER_MODE = INSIDE
BORDER_RADIUS = 14
BORDER_WIDTH = 4
BORDER_R = 123
BORDER_G = 88
BORDER_B = 220
BORDER_A = 1.0
SMART_HIDE_BORDER = False
NO_VERSION_NOTIFY = False
OFFSETS = [0, 0, 0, 0]  # [pos_x, pos_y, neg_x, neg_y]


def _load_gi():
    """Load GI modules in a Ruff-friendly way while keeping require_version ordering correct."""
    gi.require_version("Gtk", "3.0")
    gi.require_version("Gdk", "3.0")
    gi.require_version("Wnck", "3.0")
    gi.require_version("GObject", "2.0")
    from gi.repository import Gdk, GObject, Gtk, Wnck  # type: ignore[import-not-found]

    return Gtk, Gdk, Wnck, GObject


Gtk, Gdk, Wnck, GObject = _load_gi()


def set_border_rgba(args: argparse.Namespace) -> None:
    try:
        literal_value = int(args.border_rgba.replace("#", "0x"), 16)
    except ValueError as e:
        raise ValueError(
            f"`{args.border_rgba}` is an invalid hexadecimal number!"
        ) from e

    # #RRGGBBAA
    if len(args.border_rgba) == 4 * 2 + 1:
        args.border_red = (literal_value >> (3 * 8)) & 0xFF
        args.border_green = (literal_value >> (2 * 8)) & 0xFF
        args.border_blue = (literal_value >> (1 * 8)) & 0xFF
        args.border_alpha = ((literal_value >> (0 * 8)) & 0xFF) / 255.0
    # #RRGGBB
    elif len(args.border_rgba) == 3 * 2 + 1:
        args.border_red = (literal_value >> (2 * 8)) & 0xFF
        args.border_green = (literal_value >> (1 * 8)) & 0xFF
        args.border_blue = (literal_value >> (0 * 8)) & 0xFF
        args.border_alpha = 1.0
    else:
        raise ValueError(
            f"`{args.border_rgba}` is an invalid hexadecimal color string."
        )


def get_args() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--config", "-c", type=str, help="The path to the config file")
    parser.add_argument(
        "--border-radius", type=int, default=14, help="The border radius, in pixels"
    )
    parser.add_argument(
        "--border-width", type=int, default=4, help="The border width in pixels"
    )
    parser.add_argument(
        "--border-red",
        type=int,
        default=123,
        help="The border's red value, between 0 and 255",
    )
    parser.add_argument(
        "--border-green",
        type=int,
        default=88,
        help="The border's green value, between 0 and 255",
    )
    parser.add_argument(
        "--border-blue",
        type=int,
        default=220,
        help="The border's blue value, between 0 and 255",
    )
    parser.add_argument(
        "--border-alpha",
        type=float,
        default=1.0,
        help="The border's alpha value, between 0 and 1",
    )
    parser.add_argument(
        "--border-rgba", default=None, help="Border color in hex, example: #FF0000FF"
    )
    parser.add_argument(
        "--border-mode",
        type=str,
        default="outside",
        help="Border placement: outside, inside, center",
    )
    parser.add_argument(
        "--smart-hide-border",
        action="store_true",
        help="Don't display a border if the window is alone in the workspace.",
    )
    parser.add_argument(
        "--disable-version-warning",
        action="store_true",
        help="Disable update notification if xborders is out of date.",
    )
    parser.add_argument(
        "--positive-x-offset",
        default=0,
        type=int,
        help="Increase window size to the right.",
    )
    parser.add_argument(
        "--negative-x-offset",
        default=0,
        type=int,
        help="Increase window size to the left.",
    )
    parser.add_argument(
        "--positive-y-offset", default=0, type=int, help="Increase window size upwards."
    )
    parser.add_argument(
        "--negative-y-offset",
        default=0,
        type=int,
        help="Increase window size downwards.",
    )
    parser.add_argument(
        "--version", action="store_true", help="Print the version of xborders and exit."
    )
    args = parser.parse_args()

    if args.version:
        print(f"xborders v{VERSION}")
        raise SystemExit(0)

    if args.border_rgba is not None:
        set_border_rgba(args)

    # Load config (if provided) — supports either dashed or underscored keys
    if args.config is not None:
        with open(args.config, "r", encoding="utf-8") as f:
            raw = f.read().replace("-", "_")
            dat = json.loads(raw)
            for ident, value in dat.items():
                if ident == "border_rgba":
                    args.border_rgba = value
                    set_border_rgba(args)
                else:
                    args.__dict__[ident] = value

    global BORDER_RADIUS, BORDER_WIDTH, BORDER_MODE, BORDER_R, BORDER_G, BORDER_B, BORDER_A
    global SMART_HIDE_BORDER, NO_VERSION_NOTIFY, OFFSETS

    BORDER_RADIUS = int(args.border_radius)
    BORDER_WIDTH = int(args.border_width)
    BORDER_R = int(args.border_red)
    BORDER_G = int(args.border_green)
    BORDER_B = int(args.border_blue)
    BORDER_A = float(args.border_alpha)
    NO_VERSION_NOTIFY = bool(args.disable_version_warning)
    SMART_HIDE_BORDER = bool(args.smart_hide_border)
    OFFSETS = [
        int(args.positive_x_offset or 0),
        int(args.positive_y_offset or 0),
        int(args.negative_x_offset or 0),
        int(args.negative_y_offset or 0),
    ]

    if args.border_mode in BORDER_MODES:
        BORDER_MODE = args.border_mode
    else:
        raise ValueError(
            f"Invalid border_mode: '{args.border_mode}'. Valid border_modes are: inside, outside, center."
        )


def get_screen_size(display: Any) -> tuple[int, int]:
    # TODO: Multiple monitor size support (this already unions all monitor geometries)
    mon_geoms = [
        display.get_monitor(i).get_geometry() for i in range(display.get_n_monitors())
    ]
    x0 = min(r.x for r in mon_geoms)
    y0 = min(r.y for r in mon_geoms)
    x1 = max(r.x + r.width for r in mon_geoms)
    y1 = max(r.y + r.height for r in mon_geoms)
    return (x1 - x0, y1 - y0)


def notify_about_version(latest_version: float) -> None:
    notification_string = f"xborders has an update!  [{VERSION} 🡢 {latest_version}]"
    completed = subprocess.run(
        [
            "notify-send",
            "--app-name=xborder",
            "--expire-time=5000",
            notification_string,
            "--action=How to Update?",
            "--action=Ignore Update",
        ],
        capture_output=True,
        check=False,
    )
    if completed.returncode != 0:
        print("something went wrong in notify-send.")
        return

    result_string = completed.stdout.decode("utf-8")
    if result_string == "":
        return

    try:
        result = int(result_string)
    except ValueError:
        return

    if result == 1:
        our_location = os.path.dirname(os.path.abspath(__file__))
        with open(
            os.path.join(our_location, ".update_ignore.txt"), "w", encoding="utf-8"
        ) as f:
            f.write(str(latest_version))
    elif result == 0:
        webbrowser.open_new_tab("https://github.com/deter0/xborder#updating")


def notify_version() -> None:
    if NO_VERSION_NOTIFY:
        return

    try:
        our_location = os.path.dirname(os.path.abspath(__file__))

        url = "https://raw.githubusercontent.com/deter0/xborder/main/version.txt"
        resp = requests.get(url, allow_redirects=True, timeout=5)
        resp.raise_for_status()
        latest_version = float(resp.content.decode("utf-8").strip())

        ignore_path = os.path.join(our_location, ".update_ignore.txt")
        if os.path.isfile(ignore_path):
            with open(ignore_path, "r", encoding="utf-8") as f:
                ignored_version = float(f.read().strip())
            if ignored_version == latest_version:
                return

        if VERSION < latest_version:
            threading.Thread(
                target=notify_about_version,
                args=(latest_version,),
                daemon=True,
            ).start()

    except Exception:
        subprocess.Popen(
            [
                "notify-send",
                "--app-name=xborders",
                "ERROR: xborders couldn't get latest version!",
            ],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )


class Highlight(Gtk.Window):
    def __init__(self, screen_width: int, screen_height: int):
        super().__init__(type=Gtk.WindowType.POPUP)

        notify_version()

        self.wnck_screen = Wnck.Screen.get_default()

        self.set_app_paintable(True)
        self.screen = self.get_screen()
        self.set_visual(self.screen.get_rgba_visual())

        # WM_CLASS / role
        self.set_role("xborder")
        self.set_wmclass("xborders", "xborder")

        self.resize(screen_width, screen_height)
        self.move(0, 0)

        self.fullscreen()
        self.set_decorated(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        self.set_keep_above(True)
        self.set_type_hint(Gdk.WindowTypeHint.NOTIFICATION)

        self.set_accept_focus(False)
        self.set_focus_on_map(False)

        self.drawingarea = Gtk.DrawingArea()
        self.drawingarea.set_events(Gdk.EventMask.EXPOSURE_MASK)
        self.add(self.drawingarea)

        # Click-through
        self.input_shape_combine_region(cairo.Region())

        self.set_title("xborders")
        self.show_all()

        self.border_path = [0.0, 0.0, 0.0, 0.0]

        # Event connection
        self.connect("draw", self._draw)
        self.connect("destroy", Gtk.main_quit)
        self.connect("composited-changed", self._composited_changed_event)
        self.wnck_screen.connect(
            "active-window-changed", self._active_window_changed_event
        )

        # Avoid memory leaks
        self.old_window = None
        self.old_signals_to_disconnect: list[int] = []

        # Initial events
        self._composited_changed_event(None)
        self._active_window_changed_event(None, None)
        self._geometry_changed_event(None)

    def _composited_changed_event(self, _arg) -> None:
        if self.screen.is_composited():
            self.move(0, 0)
        else:
            self.move(int(1e6), int(1e6))
            subprocess.Popen(
                [
                    "notify-send",
                    "--app-name=xborder",
                    "xborders requires a compositor. Resuming once a compositor is running.",
                ],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )

    def is_alone_in_workspace(self) -> bool:
        workspace = Wnck.Screen.get_active_workspace(self.wnck_screen)
        windows = Wnck.Screen.get_windows(self.wnck_screen)
        windows_on_ws = [w for w in windows if w.is_visible_on_workspace(workspace)]
        return len(windows_on_ws) == 1

    def _active_window_changed_event(self, _screen, _previous_active_window) -> None:
        # Disconnect old signals
        if self.old_window is not None and self.old_signals_to_disconnect:
            for sig_id in self.old_signals_to_disconnect:
                try:
                    GObject.signal_handler_disconnect(self.old_window, sig_id)
                except Exception:
                    pass

        self.old_signals_to_disconnect = []
        self.old_window = None

        active_window = self.wnck_screen.get_active_window()

        self.border_path = [0.0, 0.0, 0.0, 0.0]
        if active_window is not None and not (
            SMART_HIDE_BORDER and self.is_alone_in_workspace()
        ):
            geom_signal_id = GObject.signal_lookup("geometry-changed", active_window)
            state_signal_id = GObject.signal_lookup("state-changed", active_window)

            geom_has = GObject.signal_has_handler_pending(
                active_window, geom_signal_id, 0, False
            )
            state_has = GObject.signal_has_handler_pending(
                active_window, state_signal_id, 0, False
            )

            if not geom_has:
                sig_id = active_window.connect(
                    "geometry-changed", self._geometry_changed_event
                )
                self.old_signals_to_disconnect.append(sig_id)

            if not state_has:
                sig_id = active_window.connect(
                    "state-changed", self._state_changed_event
                )
                self.old_signals_to_disconnect.append(sig_id)

            self.old_window = active_window
            self._calc_border_geometry(active_window)

        self.queue_draw()

    def _state_changed_event(self, active_window, _changed_mask, new_state) -> None:
        if new_state & Wnck.WindowState.FULLSCREEN:
            self._calc_border_geometry(active_window)
        self.queue_draw()

    def _geometry_changed_event(self, _window_changed) -> None:
        active_window = self.wnck_screen.get_active_window()
        if active_window is None or (
            active_window.get_state() & Wnck.WindowState.FULLSCREEN
        ):
            self.border_path = [0.0, 0.0, 0.0, 0.0]
        else:
            self._calc_border_geometry(active_window)
        self.queue_draw()

    def _calc_border_geometry(self, window) -> None:
        if window.get_state() & Wnck.WindowState.FULLSCREEN:
            self.border_path = [0.0, 0.0, 0.0, 0.0]
            return

        # NOTE: This matches your original: get_client_window_geometry
        x, y, w, h = window.get_client_window_geometry()

        # Inside
        if BORDER_MODE == INSIDE:
            x += BORDER_WIDTH / 2
            y += BORDER_WIDTH / 2
            w -= BORDER_WIDTH
            h -= BORDER_WIDTH

        # Outside
        elif BORDER_MODE == OUTSIDE:
            x -= BORDER_WIDTH / 2
            y -= BORDER_WIDTH / 2
            w += BORDER_WIDTH
            h += BORDER_WIDTH

        # Offsets
        w += OFFSETS[0] or 0
        h += OFFSETS[1] or 0

        x -= OFFSETS[2] or 0
        w += OFFSETS[2] or 0

        y -= OFFSETS[3] or 0
        h += OFFSETS[3] or 0

        self.border_path = [float(x), float(y), float(w), float(h)]

    def _draw(self, _wid, ctx: cairo.Context) -> None:
        ctx.save()
        if self.border_path != [0.0, 0.0, 0.0, 0.0]:
            x, y, w, h = self.border_path
            if BORDER_WIDTH != 0:
                if BORDER_RADIUS > 0:
                    degrees = 0.017453292519943295  # pi/180
                    ctx.arc(
                        x + w - BORDER_RADIUS,
                        y + BORDER_RADIUS,
                        BORDER_RADIUS,
                        -90 * degrees,
                        0 * degrees,
                    )
                    ctx.arc(
                        x + w - BORDER_RADIUS,
                        y + h - BORDER_RADIUS,
                        BORDER_RADIUS,
                        0 * degrees,
                        90 * degrees,
                    )
                    ctx.arc(
                        x + BORDER_RADIUS,
                        y + h - BORDER_RADIUS,
                        BORDER_RADIUS,
                        90 * degrees,
                        180 * degrees,
                    )
                    ctx.arc(
                        x + BORDER_RADIUS,
                        y + BORDER_RADIUS,
                        BORDER_RADIUS,
                        180 * degrees,
                        270 * degrees,
                    )
                    ctx.close_path()
                else:
                    ctx.rectangle(x, y, w, h)

                ctx.set_source_rgba(
                    BORDER_R / 255.0, BORDER_G / 255.0, BORDER_B / 255.0, BORDER_A
                )
                ctx.set_line_width(BORDER_WIDTH)
                ctx.stroke()
        ctx.restore()


def main() -> None:
    get_args()
    _root = Gdk.get_default_root_window()
    _root.get_screen()
    screen_width, screen_height = get_screen_size(Gdk.Display.get_default())
    Highlight(screen_width, screen_height)
    Gtk.main()


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        raise SystemExit(0)
else:
    print(
        "xborders: This program is not meant to be imported to other Python modules. "
        "Please run xborders as a standalone script!"
    )
