# ────────────────────────────── 0. BIẾN CƠ BẢN ──────────────────────────────
set $mod Mod4
set $term kitty
set $menu ~/.config/i3/scripts/dmenu-tokyonight -p 'Run:'
set $fileman kitty yazi
set $browser zen-browser
set $sound_manager pavucontrol
set $bluetooth_manager Blueman-manager
set $text_editor neovide
set $up k
set $down j
set $left h
set $right l

# ───────────────────────────── 1. CHUNG & GAPS ─────────────────────────────
floating_modifier $mod
focus_follows_mouse yes
mouse_warping output
focus_on_window_activation smart
force_display_urgency_hint 500 ms

gaps inner 5
gaps outer 0
default_border pixel 0
default_floating_border pixel 0
hide_edge_borders both

# ────────────────────── 2. WORKSPACE (đặt tên rõ ràng) ─────────────────────
set $ws1  "1"
set $ws2  "2"
set $ws3  "3"
set $ws4  "4"
set $ws5  "5"
set $ws6  "6"
set $ws7  "7"
set $ws8  "8"
set $ws9  "9"

bindsym $mod+1  workspace $ws1
bindsym $mod+2  workspace $ws2
bindsym $mod+3  workspace $ws3
bindsym $mod+4  workspace $ws4
bindsym $mod+5  workspace $ws5
bindsym $mod+6  workspace $ws6
bindsym $mod+7  workspace $ws7
bindsym $mod+8  workspace $ws8
bindsym $mod+9  workspace $ws9

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8
bindsym $mod+Shift+9 move container to workspace $ws9

bindsym Mod1+Tab workspace back_and_forth
bindsym $mod+Shift+Tab workspace prev
bindsym $mod+Tab workspace next

bindsym Mod1+Ctrl+Right workspace next
bindsym Mod1+Ctrl+Left workspace prev

# ─────────────────────────── 3. PHÍM CƠ BẢN (APP) ──────────────────────────
bindsym $mod+Return exec --no-startup-id $term
bindsym $mod+Shift+Return exec --no-startup-id $fileman
bindsym $mod+d exec --no-startup-id $menu
bindsym $mod+b exec --no-startup-id $browser
bindsym $mod+p exec --no-startup-id $sound_manager
bindsym $mod+n exec --no-startup-id $text_editor

bindsym $mod+Shift+e exec --no-startup-id i3-nagbar -t warning -m 'Exit i3?' -b 'Yes' 'i3-msg exit'
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

bindsym $mod+q kill

bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

bindsym $mod+a focus parent
bindsym $mod+Shift+a focus child

# ───────────────────────── 4. DI CHUYỂN & LAYOUT ───────────────────────────
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

bindsym $mod+v split toggle
bindsym $mod+f fullscreen toggle

bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# ─────────────────────────── 5. CHỤP MÀN HÌNH ──────────────────────────────
set $shot_dir Pictures/Screenshots

bindsym --release Print exec --no-startup-id sh -c 'command -v flameshot >/dev/null && flameshot gui || scrot -s "$shot_dir/%Y-%m-%d_%H-%M-%S.png"'
bindsym --release $mod+Shift+s exec --no-startup-id sh -c 'command -v flameshot >/dev/null && flameshot gui || scrot "$shot_dir/%Y-%m-%d_%H-%M-%S.png"'
bindsym --release $mod+Print exec --no-startup-id sh -c 'command -v flameshot >/dev/null && flameshot screen -p "$shot_dir" || scrot -s "$shot_dir/%Y-%m-%d_%H-%M-%S.png"'

# ─────────────────────────── 6. ÂM LƯỢNG & SÁNG ────────────────────────────
bindsym XF86AudioRaiseVolume exec --no-startup-id ~/.config/i3/scripts/notify-volume up
bindsym XF86AudioLowerVolume exec --no-startup-id ~/.config/i3/scripts/notify-volume down
bindsym XF86AudioMute        exec --no-startup-id ~/.config/i3/scripts/notify-volume toggle
bindsym XF86AudioMicMute     exec --no-startup-id ~/.config/i3/scripts/mic-toggle

bindsym XF86MonBrightnessUp   exec --no-startup-id ~/.config/i3/scripts/notify-brightness up
bindsym XF86MonBrightnessDown exec --no-startup-id ~/.config/i3/scripts/notify-brightness down

bindsym XF86AudioPlay  exec playerctl -a play-pause
bindsym XF86AudioStop  exec playerctl -a pause
bindsym XF86AudioNext  exec playerctl -a next
bindsym XF86AudioPrev  exec playerctl -a previous

# ─────────────────────────────── 7. CHẾ ĐỘ RESIZE ──────────────────────────
mode "resize-tiling" {

       bindsym $left       resize shrink width 10 px or 10 ppt
       bindsym $down       resize grow height 10 px or 10 ppt
       bindsym $up         resize shrink height 10 px or 10 ppt
       bindsym $right      resize grow width 10 px or 10 ppt

       bindsym Left        resize shrink width 5 px or 5 ppt
       bindsym Down        resize grow height 5 px or 5 ppt
       bindsym Up          resize shrink height 5 px or 5 ppt
       bindsym Right       resize grow width 5 px or 5 ppt

       bindsym Return mode "default"
       bindsym Escape mode "default"
}

mode "resize-floating" {

       bindsym $left       resize shrink width 100 px or 100 ppt
       bindsym $down       resize grow height 100 px or 100 ppt
       bindsym $up         resize shrink height 100 px or 100 ppt
       bindsym $right      resize grow width 100 px or 100 ppt

       bindsym Left        resize shrink width 10 px or 10 ppt
       bindsym Down        resize grow height 10 px or 10 ppt
       bindsym Up          resize shrink height 10 px or 10 ppt
       bindsym Right       resize grow width 10 px or 10 ppt

       bindsym Return mode "default"
       bindsym Escape mode "default"
}
bindsym $mod+r exec --no-startup-id ~/.config/i3/scripts/i3-smart-resize

# ─────────────────────────── 8. LOGOUT... MODE ─────────────────────────────
bindsym $mod+0 mode "$mode_system"

set $mode_system System: (k) lock, (l) logout, (u) suspend, (h) hibernate, (r) reboot, (s) shutdown
mode "$mode_system" {

    bindsym k exec --no-startup-id ~/.config/i3/scripts/i3exit.sh lock, mode "default"
    bindsym l exec --no-startup-id ~/.config/i3/scripts/i3exit.sh logout, mode "default"
    bindsym u exec --no-startup-id ~/.config/i3/scripts/i3exit.sh suspend, mode "default"
    bindsym h exec --no-startup-id ~/.config/i3/scripts/i3exit.sh hibernate, mode "default"
    bindsym r exec --no-startup-id ~/.config/i3/scripts/i3exit.sh reboot, mode "default"
    bindsym s exec --no-startup-id ~/.config/i3/scripts/i3exit.sh shutdown, mode "default"

    bindsym Return mode "default"
    bindsym Escape mode "default"
}

# ─────────────────────────── 10. QUY TẮC CỬA SỔ ─────────────────────────────
for_window [class="firefox-developer-edition|zen" window_role="About|Dialog|Organizer"] floating enable
for_window [class="firefox-developer-edition|zen" title="^Library|^Donwloads"] floating enable
for_window [class="firefox-developer-edition|zen" title=".*Google Accounts.*"] floating enable, resize set 75 ppt 75 ppt
for_window [class="firefox-developer-edition|zen" window_role="^page-info$"] floating enable, resize set 75 ppt 75 ppt

for_window [class="flameshot" window_type="normal"] floating enable

for_window [window_type="dialog|utility|pop-up|bubble"] floating enable

for_window [class="$sound_manager|$bluetooth_manager|Nm-connection-editor|Lxappearance|Qtconfig-qt4|qt5ct|Arandr|easyeffects|Nwg-look|org.gnome.SoundRecorder|matplotlib|Upscayl|baobab|mpv|kooha|matplotlib|r_x11|R_x11|Thunar"] floating enable, resize set 75 ppt 75 ppt, move position center

for_window [class="neovide"] floating enable, resize set 75 ppt 60 ppt, move position center

for_window [class="idea"] floating enable, resize set 75 ppt 25 ppt, move container to workspace number 3

for_window [class="Spotify"] move to scratchpad

for_window [class="Plant vs Zombie"] move container to workspace number 3

for_window [class="Arandr"] floating enable, resize set 50 ppt 50 ppt, move position center

for_window [title="^cava*"] floating enable, move position center

# ────────────────────────────── 9. AUTOSTART SAFE ──────────────────────────

exec --no-startup-id numlockx

exec_always --no-startup-id xrdb -merge ~/.Xresources

exec --no-startup-id xsettingsd

exec --no-startup-id dex -a -s /etc/xdg/autostart:~/.config/autostart

exec --no-startup-id sh -c 'ibus-daemon -drx; sleep 4; ibus engine Bamboo::Candy'

exec --no-startup-id light-locker

exec --no-startup-id dbus-update-activation-environment --systemd DISPLAY XAUTHORITY XDG_CURRENT_DESKTOP WAYLAND_DISPLAY

exec --no-startup-id sh -c '! pidof easyeffects >/dev/null && easyeffects --gapplication-service'

exec --no-startup-id blueman-applet

exec --no-startup-id sh -c 'sleep 2; easyeffects -l "LoudnessCrystalEqualizer"'

exec_always --no-startup-id picom -c ~/.config/picom/picom.conf

exec --no-startup-id ~/.config/i3/scripts/xwinwrap

exec_always --no-startup-id ~/.config/i3/scripts/xborders --border-radius 10 --border-width 3 --disable-version-warning --border-rgba "#cba6f7"

# ────────────────────────────── 10. THANH BAR ──────────────────────────────
exec_always --no-startup-id ~/.config/polybar/candy/launch.sh

