#!/usr/bin/env bash
# insert-mic: prepend a microphone block into any i3bar JSON stream
# Usage: <existing status_command> | insert-mic

read -r header && echo "$header"
read -r start && echo "$start"

while IFS= read -r line; do
  if pactl info >/dev/null 2>&1; then
    mute=$(pactl get-source-mute @DEFAULT_SOURCE@ 2>/dev/null | awk '{print $2}')
    vol=$(pactl get-source-volume @DEFAULT_SOURCE@ 2>/dev/null | awk -F'/' 'NR==1{gsub(/ /,""); print $2}')
    if [ "$mute" = "yes" ] || [ -z "$vol" ]; then
      text="  MUTED"
      color="#81a1c1"
      #text=" mic: muted"
      #color="#ff5555"
    else
      text=" MIC: $vol"
      color="#a6e3a1"
    fi
  else
    text="🎤 MIC: n/a"
    color="#aaaaaa"
  fi

  mic_block=$(jq -cn --arg text "$text" --arg color "$color" \
    '{name:"mic", full_text:" \($text) ", color:$color}')

  if [[ "$line" == ,[* ]]; then
    echo ",[ $mic_block, ${line:2}"
  elif [[ "$line" == [* ]]; then
    echo "[ $mic_block, ${line:1}"
  else
    echo "$line"
  fi
done
