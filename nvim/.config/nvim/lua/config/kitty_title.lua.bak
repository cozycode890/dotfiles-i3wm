-- lua/options/title.lua
local uv = vim.uv or vim.loop

local M = {}

-- ── ENV FLAGS ─────────────────────────────────────────────────────────────
M.is_neovide = (vim.g.neovide == true) or (vim.g.neovide == 1) or (vim.g.neovide == "true")
M.is_kitty = (vim.env.TERM == "xterm-kitty") or (vim.env.KITTY_WINDOW_ID ~= nil)
M.use_tab_title = M.is_kitty or M.is_neovide

-- (Giữ tương thích nếu nơi khác có require("config.env"))
package.loaded["config.env"] = M

-- ── BUILD TITLE ──────────────────────────────────────────────────────────
local MODE = { n = "N", i = "I", v = "V", V = "V·L", ["\22"] = "V·B", R = "R" }

local function build_title()
  local cwd = vim.fn.fnamemodify((uv.cwd() or ""), ":t")
  local file = vim.fn.expand("%:t")
  local mode = MODE[(vim.api.nvim_get_mode() or {}).mode or ""] or vim.fn.mode()
  local head = vim.b.gitsigns_head
  local br = head and (" " .. head) or ""
  local e = #vim.diagnostic.get(0, { severity = vim.diagnostic.severity.ERROR })
  local w = #vim.diagnostic.get(0, { severity = vim.diagnostic.severity.WARN })
  local diag = (e + w > 0) and ("E" .. e .. " W" .. w) or ""

  local parts = { " NVIM", mode, cwd, (file == "" and "[No Name]" or file), br, diag }
  local out = {}
  for _, s in ipairs(parts) do
    if s and s ~= "" then
      out[#out + 1] = s
    end
  end
  return table.concat(out, "  •  ")
end

-- ── SYNC TITLE (Neovim titlestring + Kitty tab title) ────────────────────
local function sync_title()
  if not M.use_tab_title then
    return
  end
  vim.o.title = true
  local txt = build_title()
  vim.o.titlestring = txt

  if M.is_kitty and vim.env.KITTY_WINDOW_ID then
    -- đặt tab title của Kitty (không chặn UI)
    vim.fn.jobstart({ "kitty", "@", "set-tab-title", txt }, { detach = true })
  end
end

-- ── PUBLIC API ───────────────────────────────────────────────────────────
function M.setup()
  if not M.use_tab_title then
    return
  end

  local grp = vim.api.nvim_create_augroup("TabTitleSync", { clear = true })
  vim.api.nvim_create_autocmd({
    "VimEnter",
    "BufEnter",
    "BufWritePost",
    "DirChanged",
    "ModeChanged",
    "DiagnosticChanged",
    "LspAttach",
    "LspDetach",
  }, {
    group = grp,
    callback = sync_title,
  })

  sync_title()
end

return M
