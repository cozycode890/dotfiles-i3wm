return {
	{
		"stevearc/conform.nvim",
		opts = {
			formatters_by_ft = {
				r = { "styler" },
				rmd = { "styler" }, -- tùy chọn
			},
			formatters = {
				styler = {
					command = "Rscript",
					stdin = true,
					args = {
						"-e",
						[[
            con <- file("stdin"); code <- readLines(con, warn=FALSE); close(con);
            cat(styler::style_text(code), sep="\n")
            ]],
					},
				},
			},
		},
	},
}
