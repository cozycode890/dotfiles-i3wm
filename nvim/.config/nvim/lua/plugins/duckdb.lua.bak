return {
  {
    "nvim-lua/plenary.nvim",
    lazy = true,
  },
  {
    -- không cần plugin DB; dùng terminal nổi
    "folke/which-key.nvim", -- đã có sẵn trong LazyVim
    keys = {
      -- <leader>cp = CSV Preview (DuckDB)
      {
        "<leader>cp",
        function()
          local api = vim.api
          local fname = vim.fn.expand("%:p")
          if fname == "" or vim.fn.getftype(fname) ~= "file" then
            vim.notify("Không phải file thường.", vim.log.levels.WARN)
            return
          end
          -- Lệnh DuckDB: đọc CSV tự động + giới hạn dòng
          local sql = string.format(
            [[.mode box
.headers on
SELECT * FROM read_csv_auto('%s') LIMIT 200;]],
            fname:gsub("'", "''")
          )

          -- Tạo floating win + term
          local buf = api.nvim_create_buf(false, true)
          local width = math.floor(vim.o.columns * 0.9)
          local height = math.floor(vim.o.lines * 0.9)
          local row = math.floor((vim.o.lines - height) / 2)
          local col = math.floor((vim.o.columns - width) / 2)
          api.nvim_open_win(buf, true, {
            relative = "editor",
            row = row,
            col = col,
            width = width,
            height = height,
            style = "minimal",
            border = "rounded",
          })
          api.nvim_buf_set_option(buf, "bufhidden", "wipe")
          vim.fn.termopen({ "bash", "-lc", "PAGER='pspg -s 14' duckdb" }, {
            on_exit = function(_, code)
              if code ~= 0 then
                vim.schedule(function()
                  vim.notify("Không tìm thấy `duckdb` trong PATH.", vim.log.levels.ERROR)
                end)
              end
            end,
          })
          -- Gửi câu lệnh vào terminal
          vim.defer_fn(function()
            vim.api.nvim_chan_send(vim.b.terminal_job_id, sql .. "\n.exit\n")
          end, 100)
        end,
        desc = "Preview CSV bằng DuckDB (floating)",
        mode = "n",
      },
    },
  },
}
