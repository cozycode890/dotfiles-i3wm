return {
  { "nvim-mini/mini.surround", enabled = false },

  {
    "kylechui/nvim-surround",
    version = "*",
    -- Dùng 'keys' để LazyVim autoload ngay khi bấm, tránh việc plugin chưa load nên không có map
    keys = {
      { "ys", mode = "n", desc = "Add surround (nvim-surround)" },
      { "ds", mode = "n", desc = "Delete surround (nvim-surround)" },
      { "cs", mode = "n", desc = "Change surround (nvim-surround)" },
      { "S", mode = "v", desc = "Surround selection (nvim-surround)" },
    },
    config = true, -- = require("nvim-surround").setup()
  },
}
