{
  "keyboard.dispatch": "keyCode", // fix phím Esc/Alt trên Linux
  "editor.smoothScrolling": true,
  "editor.scrollBeyondLastLine": false,
  "editor.mouseWheelScrollSensitivity": 0.6,
  "editor.fastScrollSensitivity": 2,
  "workbench.list.smoothScrolling": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "security.workspace.trust.untrustedFiles": "open",
  "security.workspace.trust.enabled": false,
  "editor.minimap.enabled": false,
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "zenMode.hideLineNumbers": false,
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "files.autoSave": "afterDelay",
  "notebook.formatOnSave.enabled": true,
  "notebook.gotoSymbols.showAllSymbols": false,
  "notebook.outline.showCodeCells": true,
  "notebook.outline.showCodeCellSymbols": false,
  "editor.mouseWheelZoom": true,
  "markdown.preview.fontFamily": "'3270 Nerd Font'",
  "terminal.integrated.fontFamily": "'Caskaydia Nerd Font'",
  "markdown.preview.breaks": true,
  "editor.largeFileOptimizations": false,
  "terminal.integrated.cwd": "${fileDirname}",
  "explorer.confirmDelete": false,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.fontSize": 18,
  "editor.fontFamily": "CaskaydiaCove Nerd Font, Consolas, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "typescript.suggest.paths": false,
  "javascript.suggest.paths": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "chat.agent.enabled": false,
  "terminal.integrated.fontSize": 16,
  "redhat.telemetry.enabled": false,
  "workbench.navigationControl.enabled": false,
  "chat.commandCenter.enabled": false,
  "workbench.layoutControl.enabled": false,
  "window.commandCenter": false,
  "workbench.secondarySideBar.showLabels": false,
  "editor.autoIndentOnPaste": true,
  "settingsSync.ignoredExtensions": [
    "vscode.theme-kimbie-dark"
  ],
  "workbench.colorTheme": "Tokyo Night",
  "terminal.integrated.fontLigatures.enabled": true,
  "jdk.telemetry.enabled": true,
  "editor.formatOnSave": true,
  "r.rterm.linux": "/usr/bin/radian",
  "r.bracketedPaste": true,
  "r.plot.useHttpgd": true,
  "r.alwaysUseActiveTerminal": true,
  "window.menuBarVisibility": "toggle",
  "window.density.editorTabHeight": "compact",
  "editor.lineNumbers": "relative",
  "quarto.visualEditor.lineNumbers": true,
  "vim.useSystemClipboard": true,
  "workbench.sideBar.location": "right",
  "workbench.activityBar.location": "default",
  "vim.useCtrlKeys": false,
  "vim.handleKeys": {
    "<C-Enter>": false, // Run Cell
    "<S-Enter>": false, // Run + Select Below
    "<A-Enter>": false, // Run + Insert Below
    "<C-S-Enter>": false, // Run Above (tuỳ layout)
    "<C-Space>": false, // Trigger Suggest/IntelliSense trong cell
    "<C-/>": false, // Toggle line comment trong cell
    "<C-S-/>": false, // Block comment (tuỳ keymap)
    "<A-Down>": false, // Move line/selection down (hay dùng khi thao tác cell)
    "<A-Up>": false, // Move line/selection up
    "<C-S-p>": false, // Command Palette
    "<C-p>": false, // Quick Open
    "<C-n>": false, // New file (hoặc next item trong quick pick)
    "<C-o>": false, // Open file
    "<C-s>": false, // Save
    "<C-S-s>": false, // Save As
    "<C-w>": false, // Close editor
    "<C-Tab>": false, // Next editor
    "<C-S-Tab>": false, // Prev editor
    "<C-`>": false, // Toggle Integrated Terminal
    "<C-b>": false, // Toggle Sidebar
    "<C-\\>": false, // Split editor
    "<C-k>": false, // (tiền tố nhiều chord của VSCode, nhả để VSCode xử lý)
    "<C-a>": false, // Select all / move to BOL (tuỳ chế độ)
    "<C-e>": false, // Move to EOL / suggest (tuỳ ngữ cảnh)
    "<C-f>": false, // Find
    "<C-h>": false, // Replace
    "<C-y>": false, // Redo/Scroll line up (tránh nuốt redo của VSCode tuỳ keymap)
    "<C-z>": false, // Undo (khi bạn muốn undo của VSCode thống nhất mọi ngữ cảnh)
    "<C-x>": false, // Cut
    "<C-c>": false, // Copy
    "<C-v>": false, // Paste
    "<C-l>": false, // Expand line selection (VSCode) / (Vim hay dùng <C-l> để clear highlight)
    "<C-j>": false, // Join lines/Next item (tuỳ keymap VSCode)
    "<C-t>": false, // New tab / Reopen closed tab (tuỳ keymap)
    "<C-r>": false, // Redo / History (tuỳ keymap)
    "<C-q>": false, // Quit multi-cursor / Toggle recording (tuỳ)
    "<C-g>": false, // Go to line (tuỳ keymap)
    "<C-i>": false, // Show hover / Trigger suggest (tuỳ ngữ cảnh)
    // ===== Indent/Outdent, Format, Selection =====
    "<C-]>": false, // Indent line
    "<C-[>": false, // Outdent line
    "<C-S-k>": false, // Delete line
    "<C-S-\\>": false, // Toggle split / Focus split (tuỳ keymap)
    "<C-S-Alt-Down>": false, // Copy line down (nhiều layout dùng Alt+Shift+Down; thêm biến thể Ctrl để an toàn)
    "<C-S-Alt-Up>": false, // Copy line up
    // ===== Terminal/Panel/Explorer nhanh =====
    "<A-Left>": false, // Go back (workbench)
    "<A-Right>": false, // Go forward (workbench)
    "<C-;>": false, // Một số keymap dùng cho expand snippet
    "<C-' >": false // Một số keymap dùng cho peek/quotes (tuỳ layout)
  }
}